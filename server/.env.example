# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Server Configuration
PORT=3000
NODE_ENV=development

# Client origin for CORS (set to your deployed frontend URL in production)
CLIENT_URL=http://localhost:3000

# Gemma model (google/gemma-2-2b-it for CPU; gemma-4-12B-it for GPU)
GEMMA_MODEL=google/gemma-2-2b-it

# Hugging Face (required for gated Gemma models)
HF_TOKEN=your-hf-read-token-here

# Hugging Face S3-compatible storage (optional — prefixed; not used by hub loader)
HF_S3_ACCESS_KEY_ID=your-hf-s3-access-key
HF_S3_SECRET_ACCESS_KEY=your-hf-s3-secret-key
HF_S3_ENDPOINT=https://s3.hf.co/your-username
