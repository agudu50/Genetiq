		"@react-three/postprocessing": "^2.19.0",
		"@reduxjs/toolkit": "^2.5.0",
		"@supabase/supabase-js": "^2.106.1",
		"@tanstack/react-query": "^5.91.2",
		"bcrypt": "^5.1.1",
		"cors": "^2.8.5",
		"dotenv": "^16.4.7",
		"express": "^5.1.0",
		"framer-motion": "^12.37.0",
		"localforage": "^1.10.0",
		"lucide-react": "^0.577.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-icons": "^5.6.0",
		"react-redux": "^9.2.0",
