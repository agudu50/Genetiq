		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lint-staged": "^15.3.0",
		"prettier": "^3.4.2",
		"sass": "^1.83.1",
		"typescript": "~5.6.2",
		"typescript-eslint": "^8.19.1",
		"vite": "^6.0.5",
		"vite-plugin-svgr": "^4.3.0",
		"vitest": "^4.1.0"
