{
	"name": "genetiq-app",
	"private": true,
	"version": "0.0.0",
	"type": "commonjs",
	"scripts": {
		"start": "concurrently \"node ../server/index.js --watch ../server/*\" \"vite\" --kill-others --kill-others-on-fail",
