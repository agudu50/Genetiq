		"@types/node": "^22.10.6",
		"@types/react": "^18.3.18",
		"@types/react-dom": "^18.3.5",
		"@types/react-router-dom": "^5.3.3",
		"@typescript-eslint/eslint-plugin": "^8.19.1",
		"@typescript-eslint/parser": "^8.19.1",
		"@vitejs/plugin-react-swc": "^3.5.0",
